# ──────────────────────────────────────────────────────────────────
# Pandora AI Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to version control.
# ──────────────────────────────────────────────────────────────────

# ── Supabase (Authentication + Database) ──────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend also reads these (without VITE_ prefix)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Fireworks AI (LLM Inference) ───────────────────────────────────
# Get your key from: https://fireworks.ai/api-keys
FIREWORKS_API_KEY=fw_your_fireworks_api_key
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
TEMPERATURE=0.2
TOP_P=0.9
MAX_TOKENS=4096
STREAM=true

# ── Optional: Deployment URLs ──────────────────────────────────────
# Set this to your Railway backend URL when deploying to Vercel
# VITE_API_BASE_URL=https://your-railway-backend.up.railway.app
